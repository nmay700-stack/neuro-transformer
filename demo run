"""
demo_run.py
===========
Synthetic EEG demo — verifies the full pipeline WITHOUT needing .edf files.

Run this first to confirm the model trains and infers correctly.
Once it passes, swap in real CHB-MIT data via data_utils.process_subject().

What this script proves
-----------------------
1. Model forward pass works on (B, 22, 256) input
2. WeightedRandomSampler correctly handles ~100:1 class imbalance
3. Weighted CrossEntropyLoss converges on distinguishable synthetic signals
4. get_attention_maps() returns (B, 22, 22) tensors suitable for heatmaps
5. Loss decreases and accuracy increases across 5 mock epochs

Synthetic signal design
-----------------------
INTERICTAL (label 0): broadband noise — simulates normal resting-state EEG
ICTAL      (label 1): 3 Hz sinusoidal oscillation + noise
                      3 Hz = classic spike-wave discharge (SWD) frequency
                      in childhood absence epilepsy and focal seizures.
                      The frequency is chosen so the signal is visually and
                      statistically distinct from noise — making it learnable
                      in 5 epochs without a GPU.
"""

import numpy as np
import torch
import torch.nn as nn
from torch.optim import AdamW
from torch.optim.lr_scheduler import CosineAnnealingLR
from sklearn.metrics import roc_auc_score

from model      import build_model
from data_utils import EEGDataset, make_loader

# ── Reproducibility ───────────────────────────────────────────────────────────
SEED = 42
np.random.seed(SEED)
torch.manual_seed(SEED)

# ── Config ────────────────────────────────────────────────────────────────────
N_CHANNELS    = 22
N_TIMEPOINTS  = 256    # 1 second @ 256 Hz
SFREQ         = 256

N_INTERICTAL  = 2000   # ~100:1 ratio mirrors real CHB-MIT imbalance
N_ICTAL       = 20
BATCH_SIZE    = 32
N_EPOCHS      = 5
LR            = 1e-3


# ── 1. Synthetic EEG generator ────────────────────────────────────────────────

def make_synthetic_eeg(
    n_interictal: int = N_INTERICTAL,
    n_ictal:      int = N_ICTAL,
    n_channels:   int = N_CHANNELS,
    n_timepoints: int = N_TIMEPOINTS,
    sfreq:        int = SFREQ,
) -> tuple:
    """
    Generate synthetic EEG windows mimicking CHB-MIT characteristics.

    INTERICTAL: Gaussian white noise  σ=1.0
                Represents background neural activity with no structured
                oscillations — stationary, broadband.

    ICTAL:      3 Hz sine + Gaussian noise  σ=0.3
                3 Hz = delta-band spike-wave discharge, the hallmark of:
                  • Childhood absence epilepsy (CAE)
                  • Lennox-Gastaut syndrome (LGS)
                  • Focal seizures with secondary generalisation
                The sine amplitude is set to 2.0 so the SNR is clearly
                positive — the model should be able to distinguish these
                in 5 epochs on a CPU.

    Args:
        n_interictal : number of non-seizure windows
        n_ictal      : number of seizure windows
        n_channels   : EEG channels
        n_timepoints : samples per window
        sfreq        : sampling frequency (Hz)

    Returns:
        windows : (N, n_channels, n_timepoints)  float32
        labels  : (N,)                            int64
    """
    t = np.linspace(0, n_timepoints / sfreq, n_timepoints, endpoint=False)
    windows, labels = [], []

    # ── Interictal: broadband noise ───────────────────────────────────────────
    for _ in range(n_interictal):
        noise = np.random.randn(n_channels, n_timepoints).astype(np.float32)
        windows.append(noise)
        labels.append(0)

    # ── Ictal: 3 Hz SWD-like oscillation + noise ──────────────────────────────
    seizure_osc = 2.0 * np.sin(2 * np.pi * 3.0 * t)   # shape: (T,)
    for _ in range(n_ictal):
        noise = 0.3 * np.random.randn(n_channels, n_timepoints).astype(np.float32)
        signal = (seizure_osc[np.newaxis, :] + noise).astype(np.float32)
        windows.append(signal)
        labels.append(1)

    windows = np.stack(windows)                         # (N, C, T)
    labels  = np.array(labels, dtype=np.int64)

    # Shuffle
    idx = np.random.permutation(len(labels))
    return windows[idx], labels[idx]


# ── 2. Weighted loss ──────────────────────────────────────────────────────────

def build_weighted_loss(labels: np.ndarray, device: torch.device) -> nn.CrossEntropyLoss:
    """
    Inverse-frequency weighted CrossEntropyLoss.

    With 2000 interictal : 20 ictal (100:1 ratio), the ictal class weight
    is ~100×, forcing the model to treat each missed seizure as 100× more
    costly than a false alarm — appropriate for clinical monitoring where
    a missed seizure can be life-threatening.

    Weight formula: w_c = N / (n_classes × N_c)
    """
    counts  = np.bincount(labels)
    weights = len(labels) / (len(counts) * counts.astype(float))
    print(f"  Class weights → interictal: {weights[0]:.3f} | ictal: {weights[1]:.3f}")
    return nn.CrossEntropyLoss(
        weight        = torch.tensor(weights, dtype=torch.float32).to(device),
        label_smoothing = 0.05,
    )


# ── 3. Training loop ──────────────────────────────────────────────────────────

def train_epoch(model, loader, optimiser, criterion, device):
    model.train()
    total_loss, correct, total = 0.0, 0, 0
    for eeg, labels in loader:
        eeg, labels = eeg.to(device), labels.to(device)
        optimiser.zero_grad(set_to_none=True)
        logits, _ = model(eeg)
        loss = criterion(logits, labels)
        loss.backward()
        torch.nn.utils.clip_grad_norm_(model.parameters(), 1.0)
        optimiser.step()
        total_loss += loss.item() * eeg.size(0)
        correct    += (logits.argmax(1) == labels).sum().item()
        total      += eeg.size(0)
    return total_loss / total, correct / total


@torch.no_grad()
def evaluate(model, loader, criterion, device):
    model.eval()
    total_loss, correct, total = 0.0, 0, 0
    all_probs, all_labels = [], []
    for eeg, labels in loader:
        eeg, labels = eeg.to(device), labels.to(device)
        logits, _ = model(eeg)
        loss = criterion(logits, labels)
        probs = torch.softmax(logits, dim=1)[:, 1]
        total_loss += loss.item() * eeg.size(0)
        correct    += (logits.argmax(1) == labels).sum().item()
        total      += eeg.size(0)
        all_probs.append(probs.cpu().numpy())
        all_labels.append(labels.cpu().numpy())
    all_probs  = np.concatenate(all_probs)
    all_labels = np.concatenate(all_labels)
    try:
        auroc = roc_auc_score(all_labels, all_probs)
    except ValueError:
        auroc = float("nan")
    return total_loss / total, correct / total, auroc


# ── 4. Attention heatmap demo ─────────────────────────────────────────────────

def demo_attention(model, windows, labels, device, n_ictal: int = 3):
    """
    Print the top-3 most-attended electrode pairs for the first N ictal windows.

    In a real analysis you would plot these as a 22×22 heatmap overlaid on
    the 10-20 scalp topography.  Here we print the top pairs to prove the
    weights are non-trivial and interpretable.
    """
    CHANNEL_NAMES = [
        "FP1-F7","F7-T7","T7-P7","P7-O1",
        "FP1-F3","F3-C3","C3-P3","P3-O1",
        "FP2-F4","F4-C4","C4-P4","P4-O2",
        "FP2-F8","F8-T8","T8-P8","P8-O2",
        "FZ-CZ","CZ-PZ",
        "P7-T7","T7-FT9","FT9-FT10","FT10-T8",
    ]
    model.eval()
    ictal_idx = np.where(labels == 1)[0][:n_ictal]
    x = torch.from_numpy(windows[ictal_idx]).to(device)
    _, attn_maps = model.get_attention_maps(x)
    last_layer_attn = attn_maps[-1].cpu().numpy()   # (n_ictal, 22, 22)

    print("\n── Attention Heatmap Preview (final encoder layer, ictal windows) ──")
    for i in range(len(ictal_idx)):
        attn = last_layer_attn[i]
        np.fill_diagonal(attn, 0)               # ignore self-attention
        top_pairs = np.dstack(np.unravel_index(
            np.argsort(attn.ravel())[-3:], attn.shape
        ))[0][::-1]
        print(f"  Ictal window {i+1}:")
        for src, tgt in top_pairs:
            print(f"    {CHANNEL_NAMES[src]:12s} → {CHANNEL_NAMES[tgt]:12s}  "
                  f"(attn={attn[src,tgt]:.4f})")


# ── 5. Main ───────────────────────────────────────────────────────────────────

def main():
    device = (torch.device("cuda") if torch.cuda.is_available()
              else torch.device("mps")  if torch.backends.mps.is_available()
              else torch.device("cpu"))

    print("=" * 60)
    print("  Neuro-Transformer  |  Synthetic EEG Demo")
    print(f"  Device: {device}")
    print("=" * 60)

    # ── Generate synthetic data ───────────────────────────────────────────────
    print(f"\n[1/4] Generating synthetic EEG  "
          f"({N_INTERICTAL} interictal  +  {N_ICTAL} ictal windows)")
    windows, labels = make_synthetic_eeg()
    print(f"      Shape: {windows.shape}  |  "
          f"Imbalance: {(labels==0).sum()}:{(labels==1).sum()}")

    # 80/20 train/val split
    n_train = int(0.8 * len(labels))
    X_train, y_train = windows[:n_train], labels[:n_train]
    X_val,   y_val   = windows[n_train:], labels[n_train:]

    train_loader = make_loader(X_train, y_train, BATCH_SIZE, train=True)
    val_loader   = make_loader(X_val,   y_val,   BATCH_SIZE, train=False)

    # ── Build model ───────────────────────────────────────────────────────────
    print("\n[2/4] Building NeuroTransformerEncoder …")
    model = build_model().to(device)
    n_params = sum(p.numel() for p in model.parameters() if p.requires_grad)
    print(f"      Parameters: {n_params:,}")

    criterion = build_weighted_loss(y_train, device)
    optimiser = AdamW(model.parameters(), lr=LR, weight_decay=1e-4)
    scheduler = CosineAnnealingLR(optimiser, T_max=N_EPOCHS, eta_min=1e-5)

    # ── Training loop ─────────────────────────────────────────────────────────
    print(f"\n[3/4] Training for {N_EPOCHS} mock epochs …\n")
    print(f"  {'Epoch':>5}  {'Train Loss':>10}  {'Train Acc':>9}  "
          f"{'Val Loss':>8}  {'Val Acc':>7}  {'AUROC':>6}")
    print("  " + "─" * 55)

    for epoch in range(1, N_EPOCHS + 1):
        tr_loss, tr_acc                  = train_epoch(model, train_loader, optimiser, criterion, device)
        vl_loss, vl_acc, auroc           = evaluate(model, val_loader, criterion, device)
        scheduler.step()
        print(f"  {epoch:>5}  {tr_loss:>10.4f}  {tr_acc*100:>8.1f}%  "
              f"{vl_loss:>8.4f}  {vl_acc*100:>6.1f}%  {auroc:>6.4f}")

    # ── Attention heatmap preview ─────────────────────────────────────────────
    print("\n[4/4] Inspecting attention maps …")
    demo_attention(model, windows, labels, device, n_ictal=3)

    print("\n" + "=" * 60)
    print("  ✓  Demo complete. Pipeline verified.")
    print("  Next step: replace synthetic data with real .edf files")
    print("  via  data_utils.process_subject('data/chb-mit/chb01/', 'chb01')")
    print("=" * 60)


if __name__ == "__main__":
    main()
